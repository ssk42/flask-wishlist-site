# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_APP=app.py
FLASK_ENV=development

# Database
# For local development, SQLite will be used automatically
# For production (Heroku), set DATABASE_URL to PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost/wishlist

# Email configuration (required for event reminders feature)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Optional: Redis for caching (for future features)
# REDIS_URL=redis://localhost:6379/0

# Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn

# Celery (for async background tasks)
# Uses REDIS_URL by default, but can be overridden
# CELERY_BROKER_URL=redis://localhost:6379/0

# APNs push notifications for the API v1 / iOS app (optional — feature-flagged;
# the API and web app work fully without these set). See docs/API_V1.md.
# All four of APNS_KEY_ID, APNS_TEAM_ID, APNS_KEY_P8, APNS_BUNDLE_ID must be set
# to enable push; generate the .p8 key in the Apple Developer portal under
# Certificates, Identifiers & Profiles -> Keys.
# APNS_KEY_ID=your-apns-key-id
# APNS_TEAM_ID=your-apple-team-id
# APNS_KEY_P8=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# APNS_BUNDLE_ID=com.example.wishlist
# APNS_USE_SANDBOX=false
