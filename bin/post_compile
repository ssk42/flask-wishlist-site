#!/bin/bash
# Heroku Python buildpack hook: runs after pip install.
# Downloads the Playwright Chromium binary into the slug; system libraries
# come from the apt buildpack (Aptfile). set -e makes a failed browser
# install fail the build instead of silently shipping without a browser.
set -euo pipefail

echo "-----> Installing Playwright Chromium browser"
playwright install chromium
echo "-----> Playwright Chromium installed"
